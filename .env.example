# QF Network RPC (Substrate WebSocket)
VITE_QF_RPC_URL=wss://mainnet.qfnode.net

# QNS Resolver address (for .qf name resolution)
VITE_QNS_RESOLVER_ADDRESS=0xd78e5b5779ed7bdf70dad0061fbeb189836022fb

# QFPay Router address (update after deployment)
VITE_QFPAY_ROUTER_ADDRESS=0x0000000000000000000000000000000000000000

